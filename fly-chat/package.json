{
  "name": "webagt-chat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --external:@aws-sdk --external:@libsql",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@aws-sdk/client-s3": "^3.750.0",
    "@hono/node-server": "^1.14.1",
    "@libsql/client": "^0.17.2",
    "ai": "^6.0.116",
    "hono": "^4.11.9",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
